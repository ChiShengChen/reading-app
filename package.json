{
  "name": "reading-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Local-first PWA for reading photographed JP/EN books with on-device OCR + translation",
  "scripts": {
    "sync:assets": "node scripts/sync-assets.mjs",
    "predev": "npm run sync:assets",
    "dev": "vite",
    "prebuild": "npm run sync:assets",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.69.0",
    "@huggingface/transformers": "^3.8.1",
    "dexie": "^4.4.4",
    "kuromoji": "^0.1.2",
    "onnxruntime-web": "^1.26.0",
    "opencc-js": "^1.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.4",
    "sql.js": "^1.14.1",
    "tesseract.js": "^5.1.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/kuromoji": "^0.1.3",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@types/sql.js": "^1.4.11",
    "@vitejs/plugin-react": "^4.7.0",
    "@webgpu/types": "^0.1.70",
    "path-browserify": "^1.0.1",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.9.3",
    "vite": "^6.4.3",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^2.1.9"
  }
}
